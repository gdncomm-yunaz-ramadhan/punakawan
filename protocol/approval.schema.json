{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/schema/protocol/approval.schema.json",
  "title": "ApprovalRecord",
  "description": "A recorded approval decision for a policy-gated operation. See punakawan-go-typescript-detailed-plan.md §16.",
  "type": "object",
  "required": ["id", "run_id", "operation", "requested_by", "status", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "run_id": { "type": "string" },
    "operation": {
      "type": "string",
      "enum": [
        "external-write", "git-push", "pull-request-creation", "issue-creation",
        "issue-transition", "confluence-update", "existing-browser-session-access",
        "secret-access", "network-host-expansion", "destructive-filesystem-action",
        "deployment-action"
      ]
    },
    "target": { "type": "string" },
    "reason": { "type": "string" },
    "requested_by": { "type": "string", "enum": ["semar", "gareng", "petruk", "bagong"] },
    "preview": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "approved", "denied"] },
    "policy_level": {
      "type": "string",
      "enum": ["deny", "require-approval", "allow", "allow-with-constraints"]
    },
    "approved_by": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "resolved_at": { "type": "string", "format": "date-time" }
  }
}
