{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/schema/protocol/task.schema.json",
  "title": "TaskContract",
  "description": "A dependency-aware Beads work item generated from an approved plan. See punakawan-go-typescript-detailed-plan.md §10.",
  "type": "object",
  "required": ["id", "requirement_id", "repository", "scope", "acceptance_criteria", "definition_of_done"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "requirement_id": { "type": "string" },
    "jira_key": { "type": "string" },
    "beads_epic": { "type": "string" },
    "repository": { "type": "string" },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "id"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "enum": ["blocks", "discovered-from", "requires"] },
          "id": { "type": "string" }
        }
      }
    },
    "scope": { "type": "string" },
    "expected_files_or_components": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "test_requirements": { "type": "array", "items": { "type": "string" } },
    "required_evidence": { "type": "array", "items": { "type": "string" } },
    "risk_classification": { "type": "string", "enum": ["low", "medium", "high"] },
    "approval_required": { "type": "boolean" },
    "definition_of_done": { "type": "string" },
    "discovered_from": { "type": "string" }
  }
}
