{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/schema/protocol/knowledge.schema.json",
  "title": "KnowledgeRecord",
  "description": "A durable knowledge record with provenance and validity state. See punakawan-go-typescript-detailed-plan.md §7.",
  "type": "object",
  "required": ["id", "type", "status", "title", "source", "extraction", "validity"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^pkw:[a-z]+/[a-z0-9-]+/.+$" },
    "type": {
      "type": "string",
      "enum": [
        "workspace", "repository", "component", "source-artifact", "requirement",
        "acceptance-criterion", "claim", "assumption", "constraint", "decision",
        "question", "answer", "api-contract", "data-contract", "browser-flow",
        "test-case", "deployment-unit", "work-item", "change-set", "evidence",
        "external-reference", "person-or-team", "risk", "review-finding",
        "convention-profile", "context-dossier", "semar-synthesis",
        "gareng-review", "petruk-plan", "bagong-review", "final-plan",
        "retrieval-recipe"
      ]
    },
    "status": { "type": "string" },
    "title": { "type": "string" },
    "summary": {
      "description": "A short human-readable summary, indexed for search alongside title/content. See punakawan-architecture-enhancement-plan.md §10.4/§11.4.",
      "type": "string"
    },
    "content": {
      "description": "The record's full text body, the lowest-weighted BM25F search field. See §11.4/§11.5.",
      "type": "string"
    },
    "aliases": {
      "description": "Alternate names this record is also known by (e.g. an acronym or a renamed component), matched with a strong ranking bonus. See §11.7.",
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "description": "Free-form labels for filtering and search. See §11.4/§11.5.",
      "type": "array",
      "items": { "type": "string" }
    },
    "scope": {
      "description": "Where this record applies, used for search scope boosting. See §10.4/§11.10.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "organization": { "type": "string" },
        "project": { "type": "string" },
        "repository": { "type": "string" },
        "module": { "type": "string" },
        "path": { "type": "string" },
        "symbol": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "required": ["provider", "retrieved_at"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "external_id": { "type": "string" },
        "version": { "type": ["string", "integer"] },
        "uri": { "type": "string" },
        "section": { "type": "string" },
        "content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "retrieved_at": { "type": "string", "format": "date-time" }
      }
    },
    "extraction": {
      "type": "object",
      "required": ["method"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "enum": ["model-assisted", "manual", "imported"] },
        "extractor_version": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "validity": {
      "type": "object",
      "required": ["state"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "description": "draft and validating are only meaningful for retrieval-recipe records (punakawan-procedural-knowledge-retrieval-recipe-plan-final.md §12): a recipe starts draft while being taught, moves to validating during its provider dry-run, then verified once explicitly accepted. Every other record type goes straight to observed/inferred/assumed/verified.",
          "type": "string",
          "enum": ["observed", "inferred", "assumed", "verified", "disputed", "superseded", "invalid", "stale", "draft", "validating"]
        },
        "verified_by": { "type": "array", "items": { "type": "string" } },
        "verified_at": { "type": "string", "format": "date-time" }
      }
    },
    "superseded_by": {
      "description": "The id of the knowledge record that supersedes this one, set by Store.Supersede without deleting or overwriting this record. See punakawan-architecture-enhancement-plan.md §10.4.",
      "type": "string"
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "derived-from", "supersedes", "implements", "validates", "tested-by",
              "automated-by", "deployed-by", "depends-on", "blocks", "related-to",
              "conflicts-with", "owned-by", "applies-to", "verified-by",
              "discovered-from", "documented-in", "tracked-by", "observed-in",
              "assumes", "resolves", "uses-adapter", "retrieves"
            ]
          },
          "target": { "type": "string" }
        }
      }
    },
    "formatting": {
      "description": "Formatting conventions, present on convention-profile records. See §27.3.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "editorconfig": { "type": "boolean" },
        "linters": { "type": "array", "items": { "type": "string" } },
        "formatters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "structure": {
      "description": "Structural conventions, present on convention-profile records. See §27.3.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "layout": { "type": "string" },
        "package_manager": { "type": "string" },
        "test_framework": { "type": "array", "items": { "type": "string" } },
        "naming_convention": { "type": "string" }
      }
    },
    "context_dossier": {
      "description": "Semar's pre-planning context dossier, present on context-dossier records. See §9.1.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "user_goal": { "type": "string" },
        "business_or_user_value": { "type": "string" },
        "current_behavior": { "type": "string" },
        "desired_behavior": { "type": "string" },
        "explicit_non_goals": { "type": "array", "items": { "type": "string" } },
        "source_inventory": { "type": "array", "items": { "type": "string" } },
        "affected_repositories": { "type": "array", "items": { "type": "string" } },
        "existing_implementation_paths": { "type": "array", "items": { "type": "string" } },
        "existing_tests": { "type": "array", "items": { "type": "string" } },
        "api_and_data_contracts": { "type": "array", "items": { "type": "string" } },
        "deployment_path": { "type": "string" },
        "relevant_previous_decisions": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "missing_information": { "type": "array", "items": { "type": "string" } },
        "contradictions": { "type": "array", "items": { "type": "string" } },
        "confidence_level": { "type": "string" }
      }
    },
    "semar_synthesis": {
      "description": "Semar's consolidated output after merging Gareng and Petruk findings, present on semar-synthesis records. See §8.1, §9.2.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "goal": { "type": "string" },
        "scope": { "type": "string" },
        "known_facts": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "question": { "type": "string" },
              "why_it_matters": { "type": "string" },
              "observed_conflict": { "type": "string" },
              "recommended_default": { "type": "string" },
              "impact_if_unanswered": { "type": "string" },
              "blocking": { "type": "boolean" },
              "target": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "system": { "type": "string" },
                  "reference": { "type": "string" }
                }
              }
            }
          }
        },
        "affected_repositories": { "type": "array", "items": { "type": "string" } },
        "affected_components": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "recommended_workflow": { "type": "string" },
        "next_gate": { "type": "string" }
      }
    },
    "gareng_review": {
      "description": "Gareng's feasibility and risk review, present on gareng-review records. See §8.2.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verdict": { "type": "string" },
        "blocking_findings": { "type": "array", "items": { "type": "string" } },
        "non_blocking_findings": { "type": "array", "items": { "type": "string" } },
        "missing_acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "recommended_defaults": { "type": "array", "items": { "type": "string" } },
        "required_evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "petruk_plan": {
      "description": "Petruk's usefulness challenge and implementation planning output, present on petruk-plan records. See §8.3.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recommended_solution": { "type": "string" },
        "alternatives": { "type": "array", "items": { "type": "string" } },
        "tradeoffs": { "type": "array", "items": { "type": "string" } },
        "implementation_steps": { "type": "array", "items": { "type": "string" } },
        "repository_changes": { "type": "array", "items": { "type": "string" } },
        "test_plan": { "type": "array", "items": { "type": "string" } },
        "e2e_plan": { "type": "array", "items": { "type": "string" } },
        "deployment_plan": { "type": "array", "items": { "type": "string" } },
        "documentation_plan": { "type": "array", "items": { "type": "string" } }
      }
    },
    "bagong_review": {
      "description": "Bagong's independent final review, present on bagong-review records. See §8.4.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verdict": { "type": "string" },
        "requirement_coverage": { "type": "array", "items": { "type": "string" } },
        "findings": { "type": "array", "items": { "type": "string" } },
        "blocking_findings": { "type": "array", "items": { "type": "string" } },
        "test_gaps": { "type": "array", "items": { "type": "string" } },
        "security_findings": { "type": "array", "items": { "type": "string" } },
        "compatibility_findings": { "type": "array", "items": { "type": "string" } },
        "uncertainties": { "type": "array", "items": { "type": "string" } },
        "honest_summary": { "type": "string" }
      }
    },
    "final_plan": {
      "description": "Semar's final implementation plan, present on final-plan records. See §9.3.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requirements": { "type": "array", "items": { "type": "string" } },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "non_goals": { "type": "array", "items": { "type": "string" } },
        "architecture_decision": { "type": "string" },
        "data_model_impact": { "type": "string" },
        "api_impact": { "type": "string" },
        "repository_impact_map": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "implementation_sequence": { "type": "array", "items": { "type": "string" } },
        "unit_test_plan": { "type": "array", "items": { "type": "string" } },
        "integration_test_plan": { "type": "array", "items": { "type": "string" } },
        "e2e_plan": { "type": "array", "items": { "type": "string" } },
        "migration_plan": { "type": "array", "items": { "type": "string" } },
        "rollback_plan": { "type": "array", "items": { "type": "string" } },
        "observability_plan": { "type": "array", "items": { "type": "string" } },
        "documentation_plan": { "type": "array", "items": { "type": "string" } },
        "deployment_changes": { "type": "array", "items": { "type": "string" } },
        "security_considerations": { "type": "array", "items": { "type": "string" } },
        "compatibility_considerations": { "type": "array", "items": { "type": "string" } },
        "verification_criteria": { "type": "array", "items": { "type": "string" } },
        "risks_and_mitigations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "retrieval_recipe": {
      "description": "A declarative, provider-tested procedure for a recurring read-only lookup, present on retrieval-recipe records. See punakawan-procedural-knowledge-retrieval-recipe-plan-final.md §3-4. Lifecycle state lives in validity.state (reusing the shared enum, not duplicated here); this object holds recipe-specific binding, selector, and evidence data only. Immutable versioning is achieved the same way every other knowledge record is corrected: a new id/version is Put and the old one's superseded_by is set, with relations[{type:supersedes,target:<old-id>}] recording the forward link - no separate versioning mechanism is introduced.",
      "type": "object",
      "required": ["capability", "intent", "provider", "resource", "operation", "read_only", "selector", "output"],
      "additionalProperties": false,
      "properties": {
        "capability": { "description": "Capability registry identifier this recipe is bound to, e.g. jira.issue.search.", "type": "string" },
        "intent": { "description": "Typed operation intent this recipe answers, e.g. project.next-sprint.issues.", "type": "string" },
        "provider": { "type": "string" },
        "resource": { "type": "string" },
        "operation": { "type": "string" },
        "read_only": {
          "description": "Must be true for every recipe this phase's engine can execute (§14: a future write-capable ActionRecipe is a separate type, gated by the approval engine, not a flag here).",
          "type": "boolean",
          "const": true
        },
        "recipe_version": { "description": "Monotonically increasing per capability+intent+scope lineage; incremented on every accepted correction.", "type": "integer", "minimum": 1 },
        "applies_to": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "workspace_ids": { "type": "array", "items": { "type": "string" } },
            "repository_ids": { "type": "array", "items": { "type": "string" } }
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "required": { "type": "boolean" },
              "default": { "type": "string" }
            }
          }
        },
        "selector": {
          "description": "Structured selector AST (§5): a group of clauses. Bounded at two nesting levels - a clause may itself be a nested any/all group, but that group's own clauses are leaves only (field+operator+value, no further any/all). The real Jira next-sprint example never nests deeper than this; a provider needing deeper nesting is a schema revision for a later phase, not a silent extension here. No $ref/$defs is used anywhere in this repo's schemas yet, so the leaf clause shape is duplicated inline (all/any/leaf) rather than risk being the first to rely on untested go-jsonschema $ref support.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "field": { "type": "string" },
                  "operator": { "type": "string", "enum": ["equals", "not_equals", "phrase_contains", "contains", "in", "not_in", "greater_than", "less_than"] },
                  "value": {
                    "oneOf": [
                      { "type": "object", "required": ["literal"], "additionalProperties": false, "properties": { "literal": { "type": ["string", "number", "boolean"] } } },
                      { "type": "object", "required": ["resolver"], "additionalProperties": false, "properties": { "resolver": { "type": "string" }, "arguments": { "type": "object" } } }
                    ]
                  },
                  "all": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "field": { "type": "string" },
                        "operator": { "type": "string", "enum": ["equals", "not_equals", "phrase_contains", "contains", "in", "not_in", "greater_than", "less_than"] },
                        "value": {
                          "oneOf": [
                            { "type": "object", "required": ["literal"], "additionalProperties": false, "properties": { "literal": { "type": ["string", "number", "boolean"] } } },
                            { "type": "object", "required": ["resolver"], "additionalProperties": false, "properties": { "resolver": { "type": "string" }, "arguments": { "type": "object" } } }
                          ]
                        }
                      }
                    }
                  },
                  "any": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "field": { "type": "string" },
                        "operator": { "type": "string", "enum": ["equals", "not_equals", "phrase_contains", "contains", "in", "not_in", "greater_than", "less_than"] },
                        "value": {
                          "oneOf": [
                            { "type": "object", "required": ["literal"], "additionalProperties": false, "properties": { "literal": { "type": ["string", "number", "boolean"] } } },
                            { "type": "object", "required": ["resolver"], "additionalProperties": false, "properties": { "resolver": { "type": "string" }, "arguments": { "type": "object" } } }
                          ]
                        }
                      }
                    }
                  }
                }
              }
            },
            "any": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "field": { "type": "string" },
                  "operator": { "type": "string", "enum": ["equals", "not_equals", "phrase_contains", "contains", "in", "not_in", "greater_than", "less_than"] },
                  "value": {
                    "oneOf": [
                      { "type": "object", "required": ["literal"], "additionalProperties": false, "properties": { "literal": { "type": ["string", "number", "boolean"] } } },
                      { "type": "object", "required": ["resolver"], "additionalProperties": false, "properties": { "resolver": { "type": "string" }, "arguments": { "type": "object" } } }
                    ]
                  },
                  "all": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "field": { "type": "string" },
                        "operator": { "type": "string", "enum": ["equals", "not_equals", "phrase_contains", "contains", "in", "not_in", "greater_than", "less_than"] },
                        "value": {
                          "oneOf": [
                            { "type": "object", "required": ["literal"], "additionalProperties": false, "properties": { "literal": { "type": ["string", "number", "boolean"] } } },
                            { "type": "object", "required": ["resolver"], "additionalProperties": false, "properties": { "resolver": { "type": "string" }, "arguments": { "type": "object" } } }
                          ]
                        }
                      }
                    }
                  },
                  "any": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "field": { "type": "string" },
                        "operator": { "type": "string", "enum": ["equals", "not_equals", "phrase_contains", "contains", "in", "not_in", "greater_than", "less_than"] },
                        "value": {
                          "oneOf": [
                            { "type": "object", "required": ["literal"], "additionalProperties": false, "properties": { "literal": { "type": ["string", "number", "boolean"] } } },
                            { "type": "object", "required": ["resolver"], "additionalProperties": false, "properties": { "resolver": { "type": "string" }, "arguments": { "type": "object" } } }
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "ordering": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "direction"],
            "additionalProperties": false,
            "properties": {
              "field": { "type": "string" },
              "direction": { "type": "string", "enum": ["ascending", "descending"] }
            }
          }
        },
        "output": {
          "type": "object",
          "required": ["entity_type", "identity_field", "fields"],
          "additionalProperties": false,
          "properties": {
            "entity_type": { "type": "string" },
            "identity_field": { "type": "string" },
            "fields": { "type": "array", "items": { "type": "string" } }
          }
        },
        "validation": {
          "description": "The most recent validation/acceptance report (§9, §4's validation: block). Sample results and full compiled-query text are stored as evidence records, referenced by id here, not inlined.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "enum": ["pending", "passed", "failed"] },
            "validation_id": { "type": "string" },
            "provider_instance_fingerprint": { "type": "string" },
            "compiled_query_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "sample_size": { "type": "integer" },
            "accepted_result_count": { "type": "integer" },
            "accepted_by": { "type": "string" },
            "accepted_at": { "type": "string", "format": "date-time" },
            "evidence_ids": { "type": "array", "items": { "type": "string" } }
          }
        },
        "last_execution": {
          "description": "The most recent execution's evidence summary (§13). Full history lives in evidence records referenced by evidence_id; this is only the latest, for quick display.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "session_id": { "type": "string" },
            "task_id": { "type": "string" },
            "executed_at": { "type": "string", "format": "date-time" },
            "bindings": { "type": "object" },
            "compiled_query_hash": { "type": "string" },
            "result_count": { "type": "integer" },
            "provider_request_id": { "type": "string" },
            "status": { "type": "string", "enum": ["success", "failure"] },
            "evidence_id": { "type": "string" }
          }
        }
      }
    }
  }
}
